{
  "theme": {
    "mode": "light",
    "light": "One Light",
    "dark": "One Dark"
  },
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 15,
  "soft_wrap": "editor_width",
  "format_on_save": "off",
  "confirm_quit": false,
  "scrollbar": { "show": "auto" },
  "file_scan_exclusions": [
    "**/.git",
    "**/.DS_Store",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/*.pyc",
    "**/*.pyo",
    "**/.venv",
    "**/venv",
    "**/.tox",
    "**/.coverage",
    "**/htmlcov",
    "**/build",
    "**/dist",
    "**/*.egg-info",
    "**/node_modules"
  ],
  "languages": {
    "Python": {
      "format_on_save": "off"
    }
  }
}
